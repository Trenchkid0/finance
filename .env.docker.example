# =============================================================================
# Maybe Finance — Docker compose environment template
#
#   1. cp .env.docker.example .env.docker
#   2. Generate secret: `openssl rand -base64 32` atau `npx auth secret`
#   3. Isi semua nilai yang ditandai REQUIRED.
#   4. docker compose --env-file .env.docker up -d
#
# Catatan: file ini berbeda dari `.env` (yang dipakai untuk `npm run dev`
# di host). Compose membaca `.env.docker` lewat flag `--env-file`,
# bukan otomatis. Boleh juga rename ke `.env` kalau cuma jalan via
# Docker (nama default yang dibaca compose).
# =============================================================================

# --- MySQL credentials (dipakai service `db` + dirakit jadi DATABASE_URL) ---
MYSQL_DATABASE=maybe_finance
MYSQL_USER=maybe
# REQUIRED
MYSQL_PASSWORD=ganti-password-yang-kuat
# REQUIRED
MYSQL_ROOT_PASSWORD=ganti-root-password-yang-kuat

# --- Connection string yang dipakai container `app` & `migrate` -------------
# Hostname `db` adalah nama service di compose network — JANGAN ganti
# ke localhost atau 127.0.0.1, koneksi container tidak akan resolve.
DATABASE_URL_INTERNAL=mysql://maybe:ganti-password-yang-kuat@db:3306/maybe_finance

# --- NextAuth.js / Auth.js ---------------------------------------------------
# REQUIRED. Generate: `openssl rand -base64 32` atau `npx auth secret`
AUTH_SECRET=
# Public URL aplikasi. Di local docker pakai http://localhost:3000.
# Di produksi ganti ke domain HTTPS Anda.
AUTH_URL=http://localhost:3000

# --- AI assist (opsional) ----------------------------------------------------
# Kosongkan kalau tidak pakai fitur Scan AI di TransactionForm
# atau endpoint POST /api/v1/ai/scan.
DEEPSEEK_API_KEY=

# --- Lainnya -----------------------------------------------------------------
# Port di host yang di-bind ke port 3000 container app. Ubah kalau 3000 sudah dipakai.
APP_PORT=3000

# Set `true` untuk auto-jalankan `npx prisma db seed` saat container `migrate`
# pertama kali bangun (demo data: user demo@maybe.local / password123).
# Setelah seed sekali, set kembali ke `false` agar tidak menambah data ganda.
SEED_ON_STARTUP=false
