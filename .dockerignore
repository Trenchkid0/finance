# =============================================================================
# Files yang TIDAK ikut ke build context Docker.
# Tujuan: build context tipis → cache layer awet → image tidak bocor secret.
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Node
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out

# Testing
coverage
.nyc_output

# Editors
.vscode
.idea
.kiro
*.swp
*.swo

# Local environment — env aktual disuplai lewat docker-compose `env_file`.
.env
.env.local
.env.*.local
.env.development
.env.test

# Misc
*.log
*.md
README.md
LICENSE
.dockerignore
Dockerfile
docker-compose*.yml
.github
.husky

# OS junk
.DS_Store
Thumbs.db
