# =============================================================================
# Maybe Finance — Docker compose environment template
#
#   1. cp .env.docker.example .env.docker
#   2. Pilih SKENARIO koneksi database di bagian DATABASE di bawah.
#   3. Generate secret: `openssl rand -base64 32`
#   4. Isi semua nilai yang ditandai REQUIRED.
#   5. docker compose --env-file .env.docker up -d --build
#
# Catatan: file ini berbeda dari `.env` (yang dipakai untuk `npm run dev`
# di host). Compose membaca `.env.docker` lewat flag `--env-file`,
# bukan otomatis.
# =============================================================================

# =============================================================================
# DATABASE — Pilih SATU skenario sesuai setup Anda.
# =============================================================================

# -----------------------------------------------------------------------------
# Skenario A: MySQL native di HOST yang SAMA dengan Docker
#   (paling umum di server VPS atau dev lokal)
#
#   Hostname dari dalam container = host.docker.internal
#   Port default MySQL host = 3306
#
# Sebelum start:
#   1. Pastikan MySQL menerima koneksi dari Docker bridge (172.17.0.0/16
#      atau range custom Anda). Lihat blok "Konfigurasi MySQL host" di
#      docs/DEPLOY.md.
#   2. Buat database + user di MySQL host:
#        CREATE DATABASE maybe_finance CHARACTER SET utf8mb4;
#        CREATE USER 'maybe'@'%' IDENTIFIED BY 'passwordmu';
#        GRANT ALL ON maybe_finance.* TO 'maybe'@'%';
#        FLUSH PRIVILEGES;
# -----------------------------------------------------------------------------
DATABASE_URL_INTERNAL=mysql://maybe:passwordmu@host.docker.internal:3306/maybe_finance
DB_HOST=host.docker.internal
DB_PORT=3306

# -----------------------------------------------------------------------------
# Skenario B: MySQL native di SERVER LAIN (LAN / VPN / managed cloud)
#   Hostname = IP atau FQDN tujuan, mis. 192.168.18.5 atau db.internal.example.com
#
# Uncomment + isi nilai berikut, comment baris Skenario A.
# -----------------------------------------------------------------------------
# DATABASE_URL_INTERNAL=mysql://maybe:passwordmu@192.168.18.5:3306/maybe_finance
# DB_HOST=192.168.18.5
# DB_PORT=3306

# -----------------------------------------------------------------------------
# Skenario C: MySQL ikut DI-BUNDLE oleh compose (overlay)
#   Tidak perlu MySQL terinstal di host. Compose akan jalankan
#   container `db` (mysql:8.4) dan ikut dimanage bersama app.
#
# Cara start:
#   docker compose -f docker-compose.yml -f docker-compose.bundled-db.yml \
#     --env-file .env.docker up -d --build
#
# Set nilai berikut (ganti baris Skenario A):
# -----------------------------------------------------------------------------
# DATABASE_URL_INTERNAL=mysql://maybe:passwordmu@db:3306/maybe_finance
# DB_HOST=db
# DB_PORT=3306
# MYSQL_DATABASE=maybe_finance
# MYSQL_USER=maybe
# MYSQL_PASSWORD=passwordmu
# MYSQL_ROOT_PASSWORD=root-password-yang-kuat


# =============================================================================
# AUTH — NextAuth.js / Auth.js
# =============================================================================
# REQUIRED. Generate: `openssl rand -base64 32` atau `npx auth secret`
AUTH_SECRET=
# Public URL aplikasi. Di local pakai http://localhost:3000.
# Di produksi ganti ke domain HTTPS Anda.
AUTH_URL=http://localhost:3000


# =============================================================================
# OPSIONAL
# =============================================================================
# AI assist untuk fitur Scan AI di TransactionForm dan endpoint
# POST /api/v1/ai/scan. Kosongkan kalau tidak dipakai.
DEEPSEEK_API_KEY=

# Port di host yang di-bind ke port 3000 container app.
APP_PORT=3000

# Set `true` untuk auto-jalankan `npx prisma db seed` saat container
# `migrate` pertama kali bangun (data demo: demo@maybe.local / password123).
# WAJIB kembali ke `false` setelah seed pertama.
SEED_ON_STARTUP=false
