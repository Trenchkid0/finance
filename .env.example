# =============================================================================
# Maybe Finance — Environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# =============================================================================

# Database (MySQL) — see AGENTS.md §3 Tech Stack
DATABASE_URL="mysql://user:password@localhost:3306/maybe_finance"

# NextAuth.js / Auth.js
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Optional OAuth providers
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Optional: AI assist untuk fitur "Scan AI" di form transaksi.
# Daftar di https://platform.deepseek.com/ lalu salin API key di sini.
# Jika kosong, tab Scan AI akan menampilkan pesan error saat dicoba.
DEEPSEEK_API_KEY=""
